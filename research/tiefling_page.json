      <div class=\"menu-row\">\n                    <label for=\"depthmap-quality\">Max. Depth Map Size</label>\n                    <div class=\"input-range-number\">\n                        <div class=\"col col-range\">\n                            <input type=\"range\" id=\"depthmap-quality\" min=\"256\" max=\"1536\" step=\"1\" x-model=\"depthmapSize\" @input=\"updateDepthmapSize()\" list=\"depthmapSizes\">\n                            <datalist id=\"depthmapSizes\">\n                                <option value=\"518\">\n                                </option><option value=\"1024\">\n                            </option></datalist>\n                            <div class=\"range-info\">\n                                <div class=\"col col-left\">\n                                    Blocky &amp; Fast\n                                </div>\n                                <div class=\"col col-right\">\n                                    Detailed &amp; Slow\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"col col-number\">\n                            <input type=\"number\" class=\"input\" id=\"depthmap-quality-number\" step=\"1\" x-model=\"depthmapSize\" @input=\"updateDepthmapSize()\">\n                        </div>\n                    </div>\n                </div>\n                <div class=\"menu-row\">\n                    <label for=\"focus\">Depth Map Expansion</label>\n                    <div class=\"input-range-number\">\n                       <div class=\"col col-range\">\n                           <input type=\"range\" id=\"expandDepthmapRadius\" min=\"1\" max=\"20\" step=\"1\" x-model=\"expandDepthmapRadius\" @input=\"updateExpandDepthmapRadius()\" list=\"expandDepthmapRadiusList\">\n                           <datalist id=\"expandDepthmapRadiusList\">\n                               <option value=\"7\">\n                           </option></datalist>\n                           <div class=\"range-info full\">\n                               For better background separation. Only affects rendering. Tweak to avoid stretchy lines.\n                           </div>\n                       </div>\n                       <div class=\"col col-number\">\n                           <input type=\"number\" class=\"input\" id=\"expandDepthmapRadius-number\" min=\"1\" max=\"20\" step=\"1\" x-model=\"expandDepthmapRadius\" @input=\"updateExpandDepthmapRadius()\">\n                       </div>\n                    </div>\n                </div>\n                <div class=\"menu-row\">\n                    <button class=\"button states\" @click=\"loadImage()\" :disabled=\"state == 'loading'\" disabled=\"disabled\">\n                        <span class=\"state state-idle\" x-show=\"state == 'idle' || state == 'error'\" style=\"display: none;\">Generate 3D Image</span>\n                        <span class=\"state state-loading\" x-show=\"state == 'loading'\">\n                            <span>Generating</span>\n                            <span class=\"svg-wrap\">\n                                <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M12 2C12.5523 2 13 2.44772 13 3V6C13 6.55228 12.5523 7 12 7C11.4477 7 11 6.55228 11 6V3C11 2.44772 11.4477 2 12 2ZM12 17C12.5523 17 13 17.4477 13 18V21C13 21.5523 12.5523 22 12 22C11.4477 22 11 21.5523 11 21V18C11 17.4477 11.4477 17 12 17ZM22 12C22 12.5523 21.5523 13 21 13H18C17.4477 13 17 12.5523 17 12C17 11.4477 17.4477 11 18 11H21C21.5523 11 22 11.4477 22 12ZM7 12C7 12.5523 6.55228 13 6 13H3C2.44772 13 2 12.5523 2 12C2 11.4477 2.44772 11 3 11H6C6.55228 11 7 11.4477 7 12ZM19.0711 19.0711C18.6805 19.4616 18.0474 19.4616 17.6569 19.0711L15.5355 16.9497C15.145 16.5592 15.145 15.9261 15.5355 15.5355C15.9261 15.145 16.5592 15.145 16.9497 15.5355L19.0711 17.6569C19.4616 18.0474 19.4616 18.6805 19.0711 19.0711ZM8.46447 8.46447C8.07394